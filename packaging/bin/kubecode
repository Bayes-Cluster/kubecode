#!/bin/sh
set -eu

resolve_script() {
  target=$1
  while [ -L "$target" ]; do
    directory=$(CDPATH= cd -- "$(dirname -- "$target")" && pwd)
    link=$(readlink "$target")
    case "$link" in
      /*) target=$link ;;
      *) target=$directory/$link ;;
    esac
  done
  directory=$(CDPATH= cd -- "$(dirname -- "$target")" && pwd)
  printf '%s/%s\n' "$directory" "$(basename -- "$target")"
}

script=$(resolve_script "$0")
root=$(CDPATH= cd -- "$(dirname -- "$script")/.." && pwd)

: "${KUBECODE_STATIC_DIR:=$root/lib/kubecode/dist}"
: "${KUBECODE_CLAUDE_ACP_PATH:=$root/libexec/kubecode/claude-agent-acp}"
: "${KUBECODE_CODEX_ACP_PATH:=$root/libexec/kubecode/codex-acp}"

export KUBECODE_STATIC_DIR
export KUBECODE_CLAUDE_ACP_PATH
export KUBECODE_CODEX_ACP_PATH

exec "$root/lib/kubecode/kubecode-server" "$@"
