{
  "name": "kubecode",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "version": "0.1.1",
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "KUBECODE_WORKSPACE_ROOT=\"$PWD/.local/workspace\" KUBECODE_STATE_DIR=\"$PWD/.local/state\" cargo run --manifest-path server/Cargo.toml",
    "build": "tsc -b && vite build",
    "docs:check": "node --test scripts/docs-links.test.mjs && node scripts/validate-docs.mjs",
    "lint": "eslint . --max-warnings=0",
    "l10n:translate": "lara-cli translate",
    "l10n:translate:force": "lara-cli translate --force",
    "l10n:validate": "node scripts/validate-locales.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:agents:real": "cargo test --manifest-path server/Cargo.toml --test real_agents -- --ignored --nocapture",
    "test:packages": "node --test scripts/standalone.test.mjs scripts/debian-package.test.mjs",
    "test:standalone": "node --test scripts/standalone.test.mjs",
    "test:watch": "vitest",
    "playwright:smoke": "playwright test --config playwright.smoke.config.ts tests/smoke/kubecode-workspace.spec.ts",
    "test:coverage": "node scripts/run-vitest-coverage.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/react": "^10.47.0",
    "@tailwindcss/vite": "^4.1.18",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "3.4.2",
    "katex": "^0.16.28",
    "posthog-js": "^1.363.5",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.11",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "unicode-emoji-json": "^0.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@translated/lara-cli": "^1.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.5",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "1.19.13",
      "express-rate-limit": "8.2.2",
      "hono": "4.12.25",
      "ip-address": "10.1.1",
      "path-to-regexp": "8.4.0",
      "fast-uri": "3.1.2",
      "fast-xml-builder": "1.1.7",
      "flatted": "3.4.2",
      "minimatch@3.1.2": "3.1.5",
      "minimatch@3.1.3": "3.1.5",
      "minimatch@9.0.5": "9.0.9",
      "minimatch@9.0.6": "9.0.9",
      "picomatch": "4.0.4",
      "postcss": "8.5.10",
      "protobufjs": "7.6.3",
      "linkify-it": "5.0.1",
      "qs": "6.15.2",
      "rollup": "4.59.0",
      "undici": "7.25.0"
    }
  }
}
