#!/bin/sh
set -e

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$CURRENT_BRANCH" != "main" ] && [ "$CURRENT_BRANCH" != "master" ] && [ "$CURRENT_BRANCH" != "HEAD" ]; then
  echo "❌ Pushes must originate from main, master, or a detached HEAD."
  exit 1
fi

echo "🚀 Running Kubecode pre-push checks"
pnpm lint
npx tsc --noEmit
pnpm build
pnpm test:coverage
cargo fmt --manifest-path server/Cargo.toml -- --check
cargo clippy --manifest-path server/Cargo.toml -- -D warnings
cargo test --manifest-path server/Cargo.toml
pnpm playwright:smoke
echo "✅ Kubecode pre-push checks passed"
